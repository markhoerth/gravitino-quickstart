# Gravitino Quickstart Configuration
# Copy this file to .env and run ./setup.sh, or edit manually.

# Set to true to enable the Iceberg catalog (requires S3 credentials below)
ICEBERG_ENABLED=false

# S3 credentials for Iceberg catalog (only needed if ICEBERG_ENABLED=true)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
S3_ENDPOINT=
S3_ICEBERG_WAREHOUSE=
